###############################################################################
# SIDRA
# Git Attributes
###############################################################################

* text=auto eol=lf

###############################################################################
# TypeScript
###############################################################################

*.ts      text diff=typescript
*.tsx     text diff=typescript

###############################################################################
# JavaScript
###############################################################################

*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf

###############################################################################
# JSON
###############################################################################

*.json    text eol=lf

###############################################################################
# Markdown
###############################################################################

*.md      text eol=lf

###############################################################################
# HTML
###############################################################################

*.html    text eol=lf

###############################################################################
# CSS
###############################################################################

*.css     text eol=lf
*.scss    text eol=lf

###############################################################################
# YAML
###############################################################################

*.yml     text eol=lf
*.yaml    text eol=lf

###############################################################################
# Images
###############################################################################

*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.svg     text
*.webp    binary
*.avif    binary
*.ico     binary

###############################################################################
# Fonts
###############################################################################

*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary

###############################################################################
# Documents
###############################################################################

*.pdf     binary

###############################################################################
# Environment
###############################################################################

.env* text eol=lf

###############################################################################
# Lock Files
###############################################################################

package-lock.json text eol=lf
